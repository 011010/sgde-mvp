# ================================
# Database
# ================================
# Local development:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sgde_dev?schema=public"
# Neon (production) - use the pooled connection string:
# DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
# Neon (production) - use the direct/unpooled connection string for migrations:
DATABASE_URL_UNPOOLED=""

# ================================
# NextAuth
# ================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""  # Generate with: openssl rand -base64 32

# ================================
# UploadThing (v7) - File Uploads
# ================================
# Get your token from https://uploadthing.com → Dashboard → API Keys
# In v7, a single UPLOADTHING_TOKEN replaces the old UPLOADTHING_SECRET + UPLOADTHING_APP_ID
UPLOADTHING_TOKEN=""

# ================================
# Google OAuth / Drive (optional)
# ================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/integrations/google/callback"

# ================================
# Microsoft Azure / OneDrive (optional)
# ================================
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID="common"
MICROSOFT_REDIRECT_URI="http://localhost:3000/api/integrations/microsoft/callback"

# ================================
# App
# ================================
APP_NAME="SGI"
APP_URL="http://localhost:3000"
NODE_ENV="development"

# ================================
# SMTP (optional)
# ================================
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@sgdi.local"
